<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_hospital_visit_tree" model="ir.ui.view">
        <field name="name">hr.hospital.visit.tree</field>
        <field name="model">hr.hospital.visit</field>
        <field name="arch" type="xml">
            <list string="Visits">
                <field name="visit_date"/>
                <field name="doctor_id"/>
                <field name="patient_id"/>
            </list>
        </field>
    </record>

    <record id="view_hr_hospital_visit_form" model="ir.ui.view">
        <field name="name">hr.hospital.visit.form</field>
        <field name="model">hr.hospital.visit</field>
        <field name="arch" type="xml">
            <form string="Visit">
                <sheet>
                    <group>
                        <field name="visit_date"/>
                        <field name="doctor_id"/>
                        <field name="patient_id"/>
                        <field name="diagnosis"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    
    </odoo>