<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_hospital_visit_search" model="ir.ui.view">
        <field name="name">hr.hospital.visit.search</field>
        <field name="model">hr.hospital.visit</field>
        <field name="arch" type="xml">
            <search>
                <field name="doctor_id"/>
                <field name="patient_id"/>
                <field name="visit_date_planned"/>
                
                <filter string="Planned" name="filter_planned" domain="[('state', '=', 'planned')]"/>
                <filter string="Done" name="filter_done" domain="[('state', '=', 'done')]"/>
                <filter string="Cancelled" name="filter_cancelled" domain="[('state', '=', 'cancelled')]"/>
                
                <separator/>
                <filter string="This Month" name="filter_this_month" 
                        domain="[
                            ('visit_date_planned', '&gt;=', context_today().strftime('%Y-%m-01')),
                            ('visit_date_planned', '&lt;', (context_today() + relativedelta(months=1)).strftime('%Y-%m-01'))
                        ]"/>

                
                <filter string="Doctor" name="group_by_doctor" context="{'group_by': 'doctor_id'}"/>
                <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                <filter string="Visit Date" name="group_by_date" context="{'group_by': 'visit_date_planned:day'}"/>
                
            </search>
        </field>
    </record>

    <record id="view_hr_hospital_visit_calendar" model="ir.ui.view">
        <field name="name">hr.hospital.visit.calendar</field>
        <field name="model">hr.hospital.visit</field>
        <field name="arch" type="xml">
            <calendar string="Patient Visits" 
                      date_start="visit_date_planned" 
                      color="doctor_id" 
                      mode="month" 
                      quick_create="False"
                      event_open_popup="True">
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="visit_type"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="view_hr_hospital_visit_pivot" model="ir.ui.view">
        <field name="name">hr.hospital.visit.pivot</field>
        <field name="model">hr.hospital.visit</field>
        <field name="arch" type="xml">
            <pivot string="Visits Analysis" sample="1">
                <field name="doctor_id" type="row"/>
                <field name="state" type="col"/>
                <field name="visit_date_planned" interval="month" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_hr_hospital_visit_list" model="ir.ui.view">
        <field name="name">hr.hospital.visit.list</field>
        <field name="model">hr.hospital.visit</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'planned'" decoration-success="state == 'done'" decoration-muted="state == 'cancelled'">
                <field name="visit_date_planned"/>
                <field name="doctor_id"/>
                <field name="patient_id"/>
                <field name="visit_type"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_hr_hospital_visit_form" model="ir.ui.view">
        <field name="name">hr.hospital.visit.form</field>
        <field name="model">hr.hospital.visit</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="%(action_reschedule_visit_wizard)d" string="Reschedule" type="action" class="btn-primary" invisible="state != 'planned'"/>
                    <field name="state" widget="statusbar" statusbar_visible="planned,done,cancelled" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <group>
                        <group string="Planning">
                            <field name="visit_date_planned"/>
                            <field name="visit_date_actual" readonly="state != 'done'"/>
                            <field name="visit_type"/>
                        </group>
                        <group string="Participants">
                            <field name="doctor_id"/>
                            <field name="patient_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Diagnoses">
                            <field name="diagnosis_ids">
                                <list editable="bottom">
                                    <field name="disease_id"/>
                                    <field name="severity"/>
                                    <field name="is_approved" readonly="1"/>
                                    <button name="action_approve" string="Approve" type="object" icon="fa-check" invisible="is_approved"/>
                                </list>
                            </field>
                        </page>
                        <page string="Recommendations">
                            <field name="recommendations" widget="html"/>
                        </page>
                        <page string="Billing">
                            <group>
                                <field name="currency_id" invisible="1"/>
                                <field name="amount" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_hospital_visit" model="ir.actions.act_window">
        <field name="name">Patient Visits</field>
        <field name="res_model">hr.hospital.visit</field>
        <field name="view_mode">list,form,calendar,pivot</field>
        <field name="search_view_id" ref="view_hr_hospital_visit_search"/>
        <field name="context">{'search_default_filter_this_month': 1}</field>
    </record>

</odoo>