<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_hr_hospital" model="ir.module.category">
        <field name="name">Hospital</field>
        <field name="sequence">10</field>
    </record>

    <record id="privilege_hr_hospital" model="res.groups.privilege">
        <field name="name">Hospital Access</field>
        <field name="category_id" ref="hr_hospital.module_category_hr_hospital"/>
    </record>

    <record id="group_hospital_patient" model="res.groups">
        <field name="name">Patient</field>
        <field name="privilege_id" ref="hr_hospital.privilege_hr_hospital"/>
    </record>

    <record id="group_hospital_intern" model="res.groups">
        <field name="name">Intern</field>
        <field name="privilege_id" ref="hr_hospital.privilege_hr_hospital"/>
        <field name="implied_ids" eval="[(4, ref('hr_hospital.group_hospital_patient'))]"/>
    </record>

    <record id="group_hospital_doctor" model="res.groups">
        <field name="name">Doctor</field>
        <field name="privilege_id" ref="hr_hospital.privilege_hr_hospital"/>
        <field name="implied_ids" eval="[(4, ref('hr_hospital.group_hospital_intern'))]"/>
    </record>

    <record id="group_hospital_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="hr_hospital.privilege_hr_hospital"/>
        <field name="implied_ids" eval="[(4, ref('hr_hospital.group_hospital_doctor'))]"/>
    </record>

    <record id="group_hospital_administrator" model="res.groups">
        <field name="name">Administrator</field>
        <field name="privilege_id" ref="hr_hospital.privilege_hr_hospital"/>
        <field name="implied_ids" eval="[(4, ref('hr_hospital.group_hospital_manager'))]"/>
    </record>

    <record id="rule_visit_patient" model="ir.rule">
        <field name="name">Visit: Patient sees own visits</field>
        <field name="model_id" ref="hr_hospital.model_hr_hospital_visit"/>
        <field name="domain_force">[('patient_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('hr_hospital.group_hospital_patient'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_visit_intern" model="ir.rule">
        <field name="name">Visit: Intern sees own visits</field>
        <field name="model_id" ref="hr_hospital.model_hr_hospital_visit"/>
        <field name="domain_force">['|', ('patient_id.user_id', '=', user.id), ('doctor_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('hr_hospital.group_hospital_intern'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_visit_doctor" model="ir.rule">
        <field name="name">Visit: Doctor sees own and interns' visits</field>
        <field name="model_id" ref="hr_hospital.model_hr_hospital_visit"/>
        <field name="domain_force">['|', '|', ('patient_id.user_id', '=', user.id), ('doctor_id.user_id', '=', user.id), ('doctor_id.mentor_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('hr_hospital.group_hospital_doctor'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_visit_manager" model="ir.rule">
        <field name="name">Visit: Manager sees all visits</field>
        <field name="model_id" ref="hr_hospital.model_hr_hospital_visit"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr_hospital.group_hospital_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_visit_administrator" model="ir.rule">
        <field name="name">Visit: Administrator full access</field>
        <field name="model_id" ref="hr_hospital.model_hr_hospital_visit"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hr_hospital.group_hospital_administrator'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
    
</odoo>