<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_hospital_doctor_search" model="ir.ui.view">
        <field name="name">hr.hospital.doctor.search</field>
        <field name="model">hr.hospital.doctor</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="specialty_id"/>
                
                <filter string="Mentors" name="filter_mentors" domain="[('intern_ids', '!=', False)]"/>
                <filter string="Interns" name="filter_interns" domain="[('is_intern', '=', True)]"/>
                
                <separator/>
                <filter string="Specialty" name="group_specialty" context="{'group_by': 'specialty_id'}"/>
            </search>
        </field>
    </record>

    <record id="view_hr_hospital_doctor_list" model="ir.ui.view">
        <field name="name">hr.hospital.doctor.list</field>
        <field name="model">hr.hospital.doctor</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="specialty_id"/>
                <field name="license_number"/>
                <field name="rating"/>
                <field name="is_intern" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_hr_hospital_doctor_kanban" model="ir.ui.view">
        <field name="name">hr.hospital.doctor.kanban</field>
        <field name="model">hr.hospital.doctor</field>
        <field name="arch" type="xml">
            <kanban default_group_by="specialty_id">
                <field name="id"/>
                <field name="last_name"/>
                <field name="first_name"/>
                <field name="specialty_id"/>
                <field name="intern_ids"/>
                <field name="rating"/>
                <templates>
                    <t t-name="card">
                        <div class="o_dropdown_kanban dropdown">
                            <a class="dropdown-toggle o-no-caret btn" role="button" data-bs-toggle="dropdown" href="#" aria-label="Dropdown menu" title="Dropdown menu">
                                <span class="fa fa-ellipsis-v"/>
                            </a>
                            <div class="dropdown-menu" role="menu">
                                <a t-if="widget.editable" role="menuitem" type="edit" class="dropdown-item">Редагувати</a>
                                <a t-if="widget.deletable" role="menuitem" type="delete" class="dropdown-item">Видалити</a>
                            </div>
                        </div>

                        <div class="oe_kanban_global_click d-flex">
                            <div class="o_kanban_image me-3">
                                <field name="image_1920" widget="image" options="{'preview_image': 'image_128'}"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title fs-5">
                                    <field name="last_name"/> <field name="first_name"/>
                                </strong>
                                <ul class="list-unstyled mt-1">
                                    <li><strong>Спеціальність:</strong> <field name="specialty_id"/></li>

                                    <li t-if="record.intern_ids.raw_value.length > 0" class="mt-2">
                                        <i class="fa fa-users text-muted" title="Інтерни" aria-label="Інтерни" role="img"/> <strong>Інтерни:</strong>
                                        <div><field name="intern_ids" widget="many2many_tags"/></div>
                                    </li>
                                </ul>
                                <div class="mt-2">
                                    <button name="action_create_visit" type="object" class="btn btn-outline-primary btn-sm">
                                        Створити візит
                                    </button>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_hr_hospital_doctor_form" model="ir.ui.view">
        <field name="name">hr.hospital.doctor.form</field>
        <field name="model">hr.hospital.doctor</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Identity">
                            <field name="last_name"/>
                            <field name="first_name"/>
                            <field name="middle_name"/>
                            <field name="gender"/>
                        </group>
                        <group string="Professional">
                            <field name="specialty_id"/>
                            <field name="license_number"/>
                            <field name="license_date"/>
                            <field name="experience_years"/>
                            <field name="rating"/>
                            <field name="is_intern"/>
                            <field name="mentor_id" invisible="not is_intern" required="is_intern"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Interns" name="interns_page" invisible="is_intern">
                            <field name="intern_ids" mode="kanban">
                                <kanban>
                                    <field name="name"/>
                                    <field name="specialty_id"/>
                                    <templates>
                                        <t t-name="card">
                                            <div class="oe_kanban_global_click" style="border: 1px solid #ccc; padding: 10px; border-radius: 5px; margin-bottom: 5px;">
                                                <strong><field name="name"/></strong>
                                                <div class="text-muted"><field name="specialty_id"/></div>
                                            </div>
                                        </t>
                                    </templates>
                                </kanban>
                            </field>
                        </page>
                        <page string="Schedule">
                            <field name="schedule_ids">
                                <list editable="bottom">
                                    <field name="day_of_week"/>
                                    <field name="schedule_date"/>
                                    <field name="time_start" widget="float_time"/>
                                    <field name="time_end" widget="float_time"/>
                                    <field name="activity_type"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_hospital_doctor" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">hr.hospital.doctor</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_hr_hospital_doctor_search"/>
    </record>
</odoo>