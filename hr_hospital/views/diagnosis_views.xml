<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_hospital_diagnosis_pivot" model="ir.ui.view">
        <field name="name">hr.hospital.diagnosis.pivot</field>
        <field name="model">hr.hospital.diagnosis</field>
        <field name="arch" type="xml">
            <pivot string="Diagnoses Analysis" sample="1">
                <field name="disease_type_id" type="row"/>
                <field name="disease_id" type="row"/>
                
                <field name="date_of_diagnosis" type="col" interval="year"/>
                <field name="date_of_diagnosis" type="col" interval="month"/>
            </pivot>
        </field>
    </record>

    <record id="view_hr_hospital_diagnosis_graph" model="ir.ui.view">
        <field name="name">hr.hospital.diagnosis.graph</field>
        <field name="model">hr.hospital.diagnosis</field>
        <field name="arch" type="xml">
            <graph string="Disease Incidence" type="bar">
                <field name="date_of_diagnosis" interval="month"/>
                <field name="disease_type_id"/>
            </graph>
        </field>
    </record>

    <record id="action_hr_hospital_diagnosis" model="ir.actions.act_window">
        <field name="name">Diagnoses</field>
        <field name="res_model">hr.hospital.diagnosis</field>
        <field name="view_mode">list,form,pivot,graph</field>
    </record>

</odoo>