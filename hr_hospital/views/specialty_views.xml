<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_hospital_specialty_list" model="ir.ui.view">
        <field name="name">hr.hospital.specialty.list</field>
        <field name="model">hr.hospital.specialty</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="code"/>
            </list>
        </field>
    </record>

    <record id="view_hr_hospital_specialty_form" model="ir.ui.view">
        <field name="name">hr.hospital.specialty.form</field>
        <field name="model">hr.hospital.specialty</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Doctors">
                            <field name="doctor_ids" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_hospital_specialty" model="ir.actions.act_window">
        <field name="name">Specialties</field>
        <field name="res_model">hr.hospital.specialty</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>