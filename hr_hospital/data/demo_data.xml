<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="spec_cardiology" model="hr.hospital.specialty"><field name="name">Cardiology</field><field name="code">CARD-01</field></record>
        <record id="spec_surgery" model="hr.hospital.specialty"><field name="name">Surgery</field><field name="code">SURG-02</field></record>
        <record id="spec_pediatrics" model="hr.hospital.specialty"><field name="name">Pediatrics</field><field name="code">PED-03</field></record>
        <record id="spec_therapy" model="hr.hospital.specialty"><field name="name">Therapy</field><field name="code">THER-04</field></record>
        <record id="spec_neurology" model="hr.hospital.specialty"><field name="name">Neurology</field><field name="code">NEUR-05</field></record>

        <record id="dr_house" model="hr.hospital.doctor">
            <field name="last_name">House</field><field name="first_name">Gregory</field>
            <field name="specialty_id" ref="spec_neurology"/><field name="license_number">LIC-777</field>
            <field name="rating">5</field></record>

        <record id="dr_cuddy" model="hr.hospital.doctor">
            <field name="last_name">Cuddy</field><field name="first_name">Lisa</field>
            <field name="specialty_id" ref="spec_therapy"/><field name="license_number">LIC-101</field>
            <field name="rating">4</field>
        </record>

        <record id="dr_chase" model="hr.hospital.doctor">
            <field name="last_name">Chase</field><field name="first_name">Robert</field>
            <field name="specialty_id" ref="spec_surgery"/><field name="license_number">LIC-001</field>
            <field name="is_intern">True</field><field name="mentor_id" ref="dr_house"/>
            <field name="rating">3</field>
        </record>

        <record id="dr_cameron" model="hr.hospital.doctor">
            <field name="last_name">Cameron</field><field name="first_name">Allison</field>
            <field name="specialty_id" ref="spec_cardiology"/><field name="license_number">LIC-002</field>
            <field name="is_intern">True</field><field name="mentor_id" ref="dr_cuddy"/>
        </record>

        <record id="dr_wilson" model="hr.hospital.doctor">
            <field name="last_name">Wilson</field><field name="first_name">James</field>
            <field name="specialty_id" ref="spec_therapy"/><field name="license_number">LIC-999</field>
            <field name="rating">5</field>
        </record>
        
        <record id="dis_root" model="hr.hospital.disease"><field name="name">Internal Medicine</field></record>
        <record id="dis_cardio" model="hr.hospital.disease"><field name="name">Heart Diseases</field><field name="parent_id" ref="dis_root"/></record>
        <record id="dis_infarct" model="hr.hospital.disease"><field name="name">Myocardial Infarction</field><field name="parent_id" ref="dis_cardio"/><field name="severity">critical</field></record>

        <record id="patient_1" model="hr.hospital.patient">
            <field name="last_name">Doe</field><field name="first_name">John</field>
            <field name="date_of_birth">1990-01-01</field><field name="doctor_id" ref="dr_house"/>
        </record>

        <record id="patient_2" model="hr.hospital.patient">
            <field name="last_name">Smith</field><field name="first_name">Jane</field>
            <field name="date_of_birth">1985-05-12</field><field name="doctor_id" ref="dr_wilson"/>
        </record>

        <record id="visit_1" model="hr.hospital.visit">
            <field name="patient_id" ref="patient_1"/>
            <field name="doctor_id" ref="dr_house"/>
            <field name="visit_date_planned" eval="(datetime.now() + timedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="state">planned</field>
        </record>

        <record id="sched_house_mon" model="hr.hospital.doctor.schedule">
            <field name="doctor_id" ref="dr_house"/>
            <field name="day_of_week">0</field>
            <field name="time_start">9.0</field>
            <field name="time_end">17.0</field>
        </record>

    </data>
</odoo>