<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="demo_doctor_house" model="hr.hospital.doctor">
            <field name="name">Dr. House</field>
            <field name="specialization">Diagnostician</field>
        </record>

        <record id="demo_doctor_wilson" model="hr.hospital.doctor">
            <field name="name">Dr. Wilson</field>
            <field name="specialization">Oncologist</field>
            <field name="mentor_id" ref="demo_doctor_house"/>
        </record>

        <record id="demo_doctor_cameron" model="hr.hospital.doctor">
            <field name="name">Dr. Cameron</field>
            <field name="specialization">Immunologist</field>
            <field name="mentor_id" ref="demo_doctor_house"/>
        </record>
    </data>
</odoo>